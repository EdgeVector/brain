# Bun
bun.lockb

# fbrain local config (~/.fbrain/ is the canonical home, but never commit a sample with creds)
config.json
.fbrain/

# scratch
/tmp/
*.tmp

# Stray "~/" directory: fold_db can pass a literal "~/.folddb" to create_dir_all
# without expanding the tilde, leaving a real "./~/" subtree in whatever cwd it
# ran from. The data inside is safe to delete. Directory-rooted so we never
# ignore a file literally named "~" deeper in the tree.
/~/

# editor
.vscode/
.idea/
*.swp
