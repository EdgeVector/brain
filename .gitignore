node_modules/
dist/
.DS_Store
*.log

# ...but the vendored @lastdb/app-sdk IS distributed as its prebuilt dist/ — it
# has no source build step in this repo, so its dist/ must be committed. Without
# this negation the global `dist/` rule above silently drops the SDK's only
# runtime code, leaving `@lastdb/app-sdk: file:./vendor/lastdb-app-sdk` an empty
# shell when installed from a `github:` specifier.
!/vendor/lastdb-app-sdk/dist/

# Bun
bun.lockb

# fbrain local config (~/.fbrain/ is the canonical home, but never commit a sample with creds)
config.json
.fbrain/

# scratch
/tmp/
*.tmp

# Stray "~/" directory: fold_db can pass a literal "~/.folddb" to create_dir_all
# without expanding the tilde, leaving a real "./~/" subtree in whatever cwd it
# ran from. The data inside is safe to delete. Directory-rooted so we never
# ignore a file literally named "~" deeper in the tree.
/~/

# fold_db node datadir: `folddb daemon start` (README "quick try" path) defaults
# its sled DB to a RELATIVE ./data — keep that stray sled tree out of git.
# Directory-rooted so a future src/data/ or test/data/ stays trackable.
/data/

# dev-channel node datadir: the `folddb-dev` binary (app-identity publish flow,
# `folddb-dev app publish`) drops a relative ./.folddb-dev sled tree in whatever
# cwd it ran from. Same hazard as ./data above — and because `fbrain --version`
# (src/version.ts) flags `-dirty` on any `git status --porcelain` output, a
# stray .folddb-dev makes every build self-report dirty. Keep it out of git.
/.folddb-dev/

# editor
.vscode/
.idea/
*.swp
