{
  "name": "fbrain",
  "version": "0.8.0",
  "description": "fbrain — a CLI brain over fold_db (design, task, concept, preference, reference, agent, project, spike, sop, decision) with semantic search and an MCP agent surface",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/EdgeVector/fbrain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdgeVector/fbrain.git"
  },
  "bugs": {
    "url": "https://github.com/EdgeVector/fbrain/issues"
  },
  "keywords": [
    "fbrain",
    "fold_db",
    "folddb",
    "brain",
    "cli",
    "mcp",
    "semantic-search",
    "rag"
  ],
  "engines": {
    "bun": ">=1.3.10"
  },
  "bin": {
    "fbrain": "bin/fbrain",
    "fbrain-mcp": "bin/fbrain-mcp"
  },
  "files": [
    "bin",
    "src",
    "vendor",
    "tsconfig.json",
    "bunfig.toml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "fbrain": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:mcp": "scripts/build-mcp-binary.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
